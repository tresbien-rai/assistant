# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret - used for signing authentication tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Encryption Key - used for encrypting API keys and Drive tokens in the database
# Must be a 32-byte hex string (64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Google OAuth 2.0 credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project (or use existing)
# 2. Enable Google Drive API
# 3. Configure OAuth consent screen
# 4. Create OAuth 2.0 Client ID (Web application)
# 5. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Dev-only login bypass (LOCAL TESTING ONLY — never set in production)
# When NODE_ENV=development AND this is exactly "true", the server exposes
# POST /api/auth/dev-login and the login screen shows a "Dev login" button that
# signs in a local stub user without Google OAuth. The stub user has NO Google
# Drive access, so Drive-backed features (project files, tool file I/O) won't
# work for it. In production (NODE_ENV=production) the route is never registered.
# ALLOW_DEV_LOGIN=true

# Database path (optional, defaults to ./data/assistant.db)
# DB_PATH=./data/assistant.db

# Static files path (optional, defaults to ../../ which is the project root from server/src/)
# STATIC_PATH=../../
